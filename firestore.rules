rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'mardin@gmail.com';
    }

    function isValidContactInfo() {
      return request.resource.data.keys().hasOnly([
        'cards',
        'updatedAt'
      ])
      && request.resource.data.cards is list
      && request.resource.data.cards.size() <= 30
      && request.resource.data.updatedAt is string;
    }

    function isValidContactAvailability() {
      return request.resource.data.keys().hasOnly([
        'items',
        'updatedAt'
      ])
      && request.resource.data.items is list
      && request.resource.data.items.size() <= 30
      && request.resource.data.updatedAt is string;
    }

    function isOwnedContactMessageId(messageId) {
      return request.auth != null
        && (
          messageId == request.auth.uid + '__slot_1'
          || messageId == request.auth.uid + '__slot_2'
          || messageId == request.auth.uid + '__slot_3'
        );
    }

    function hasValidContactMessageContent() {
      return request.resource.data.name is string
      && request.resource.data.name.size() >= 2
      && request.resource.data.name.size() <= 100
      && request.resource.data.name.matches('.*[^\\s].*')
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 254
      && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
      && request.resource.data.subject is string
      && request.resource.data.subject.size() >= 3
      && request.resource.data.subject.size() <= 150
      && request.resource.data.subject.matches('.*[^\\s].*')
      && request.resource.data.message is string
      && request.resource.data.message.size() >= 10
      && request.resource.data.message.size() <= 3000
      && request.resource.data.message.matches('.*[^\\s].*')
      && request.resource.data.locale in ['id', 'en'];
    }

    function isValidContactMessageCreate(messageId) {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'subject',
        'message',
        'locale',
        'ownerId',
        'status',
        'createdAt',
        'updatedAt',
        'readAt'
      ])
      && isOwnedContactMessageId(messageId)
      && request.resource.data.ownerId == request.auth.uid
      && hasValidContactMessageContent()
      && request.resource.data.status == 'unread'
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time
      && request.resource.data.readAt == null;
    }

    function isValidAdminContactMessageUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'readAt'
      ])
      && request.resource.data.status in ['unread', 'read']
      && (
        (
          request.resource.data.status == 'unread'
          && request.resource.data.readAt == null
        )
        || (
          request.resource.data.status == 'read'
          && request.resource.data.readAt == request.time
        )
      );
    }

    function isValidOwnerContactMessageUpdate(messageId) {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();

      return isOwnedContactMessageId(messageId)
      && resource.data.ownerId == request.auth.uid
      && affectedKeys.hasOnly([
        'message',
        'status',
        'updatedAt',
        'readAt'
      ])
      && affectedKeys.hasAll([
        'message',
        'updatedAt'
      ])
      && request.resource.data.message is string
      && request.resource.data.message.size() >= 10
      && request.resource.data.message.size() <= 3000
      && request.resource.data.message.matches('.*[^\\s].*')
      && request.resource.data.status == 'unread'
      && request.resource.data.updatedAt == request.time
      && request.resource.data.readAt == null;
    }

    match /siteContent/contactInfo {
      allow read: if true;
      allow create, update: if isAdmin() && isValidContactInfo();
      allow delete: if false;
    }

    match /siteContent/contactAvailability {
      allow read: if true;
      allow create, update: if isAdmin() && isValidContactAvailability();
      allow delete: if false;
    }

    match /contactMessages/{messageId} {
      allow get: if isAdmin() || isOwnedContactMessageId(messageId);
      allow list: if isAdmin()
        || (
          request.auth != null
          && resource.data.ownerId == request.auth.uid
        );
      allow create: if isValidContactMessageCreate(messageId);
      allow update: if (
        isAdmin() && isValidAdminContactMessageUpdate()
      ) || isValidOwnerContactMessageUpdate(messageId);
      allow delete: if isAdmin()
        || (
          isOwnedContactMessageId(messageId)
          && resource.data.ownerId == request.auth.uid
        );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
